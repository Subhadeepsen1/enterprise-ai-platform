# Application
APP_NAME="Enterprise AI Workflow Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/enterprise_ai_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/enterprise_ai_db

# AI Models
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-8b-8192
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector DB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
FAISS_INDEX_PATH=./data/faiss_index

# File Storage
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
